def plot_fan(Yq, draws, fdates, cfg, path, n_cond):
    tcol = cfg["target_col"]
    j = list(Yq.columns).index(tcol)
    hist = Yq[tcol].iloc[-48:]
    fc = draws[:, :, j]
    fig, ax = plt.subplots(figsize=(10, 5))
    ax.plot(hist.index, hist.values, color="#1f4e79", lw=1.6, label="actual")
    ax.plot(fdates, np.median(fc, axis=0), color="#c0392b", lw=1.8,
            label="BVAR median")
    for band, alp in zip(sorted(cfg["bands"]), [0.30, 0.15]):
        lo = np.quantile(fc, (1 - band) / 2, axis=0)
        hi = np.quantile(fc, 1 - (1 - band) / 2, axis=0)
        ax.fill_between(fdates, lo, hi, color="#c0392b", alpha=alp,
                        label=f"{int(band * 100)}% band")
    ax.axhline(0, color="k", lw=0.8)
    ax.axhline(2, color="#7f8c8d", lw=0.8, ls=":")
    cond_note = (f", conditioned on {n_cond} released value(s)"
                 if n_cond else "")
    ax.set_title(f"BVAR density forecast: {tcol} "
                 f"({cfg['target_transform']}, monthly{cond_note})")
    ax.set_ylabel("percent")
    ax.legend(fontsize=8)
    fig.tight_layout(); fig.savefig(path, bbox_inches="tight"); plt.close(fig)


def plot_nowcast(cond_d, uncond_d, label, path):
    fig, ax = plt.subplots(figsize=(8, 4.2))
    ax.hist(uncond_d, bins=60, density=True, alpha=0.35, color="#7f8c8d",
            label=f"unconditional (sd={uncond_d.std():.2f})")
    ax.hist(cond_d, bins=60, density=True, alpha=0.55, color="#c0392b",
            label=f"conditional on released data (sd={cond_d.std():.2f})")
    ax.axvline(cond_d.mean(), color="#c0392b", lw=1.5)
    ax.axvline(uncond_d.mean(), color="#7f8c8d", lw=1.2, ls="--")
    ax.set_title(f"Nowcast density: {label}")
    ax.set_xlabel("percent"); ax.legend(fontsize=8)
    fig.tight_layout(); fig.savefig(path, bbox_inches="tight"); plt.close(fig)


def plot_oos(bt, cfg, path):
    fig, axes = plt.subplots(len(cfg["oos_horizons"]), 1,
                             figsize=(10, 3.6 * len(cfg["oos_horizons"])),
                             sharex=True, squeeze=False)
    for ax, h in zip(axes[:, 0], cfg["oos_horizons"]):
        b = bt[bt["h"] == h]
        ax.plot(b["origin"], b["actual"], color="k", lw=1.3, label="actual")
        ax.plot(b["origin"], b["bvar_mean"], color="#c0392b", lw=1.3,
                label="BVAR")
        ax.fill_between(b["origin"], b["bvar_lo68"], b["bvar_hi68"],
                        color="#c0392b", alpha=0.18, label="68% band")
        if h == 1 and "bvar_cond_mean" in b.columns:
            ax.plot(b["origin"], b["bvar_cond_mean"], color="#1f4e79",
                    lw=1.2, label="BVAR | CPI-block")
        ax.plot(b["origin"], b["ar_bench"], color="#7f8c8d", lw=1.0, ls="--",
                label=f"AR({cfg['n_lags']})")
