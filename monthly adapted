def _m_resample(s: pd.Series, how: str) -> pd.Series:
    try:
        r = s.resample("ME")
    except ValueError:                       # older pandas
        r = s.resample("M")
    return r.mean() if how == "mean" else r.last()


def transform(s: pd.Series, method: str) -> pd.Series:
    m = method.lower()
    if m == "level":
        return s
    if m == "diff":
        return s.diff()
    if m == "log_diff":
        return np.log(s).diff()
    if m == "ann_log_growth":                # m/m annualized, percent
        return 1200.0 * np.log(s).diff()
    if m == "yoy_log_diff":
        return 100.0 * np.log(s).diff(12)
    if m == "pct_change":
        return 100.0 * s.pct_change()
    raise ValueError(f"unknown transform {method}")


def is_growth_like(method: str) -> bool:
    return method.lower() in ("diff", "log_diff", "ann_log_growth",
                              "yoy_log_diff", "pct_change")


def _detect_frequency(idx: pd.DatetimeIndex) -> str:
    if len(idx) < 3:
        return "monthly"
    med = np.median(np.diff(idx.values).astype("timedelta64[D]").astype(int))
    return "daily_asknown" if med <= 7 else "monthly"


def load_monthly(cfg):
    """
    Returns:
      P        : full monthly panel in TRANSFORMED units (NaNs at ragged edge)
      Ybal     : balanced (dropna) training panel
      ragged   : rows after the last balanced month (the release edge)
    """
    df = pd.read_excel(cfg["excel_path"], sheet_name=cfg["sheet_name"])
    df[cfg["date_col"]] = pd.to_datetime(df[cfg["date_col"]])
    df = df.set_index(cfg["date_col"]).sort_index()
    if cfg.get("sample_end"):
        df = df[df.index <= pd.Timestamp(cfg["sample_end"])]

    cols = [cfg["target_col"]] + list(cfg["predictors"].keys())
    missing = [c for c in cols if c not in df.columns]
    if missing:
        raise KeyError(f"columns not found: {missing}; "
                       f"available: {list(df.columns)}")

    freq = cfg.get("data_frequency", "auto")
    if freq == "auto":
        freq = _detect_frequency(df.index)
        print(f"    data_frequency=auto -> detected '{freq}'")
    daily = freq == "daily_asknown"

    out = {}
    # target -- NOTE: no ffill for aligned monthly data, so the missing latest
    # PCE stays NaN and is picked up as the nowcast month.
    t_raw = df[cfg["target_col"]].ffill() if daily else df[cfg["target_col"]]
    tm = _m_resample(t_raw, "last")
    shift = int(cfg.get("target_release_shift_m", 0))
    if shift:
        tm = tm.shift(-shift)
    out[cfg["target_col"]] = transform(tm, cfg["target_transform"])

    for c, spec in cfg["predictors"].items():
        raw = df[c].ffill() if daily else df[c]
        q = _m_resample(raw, spec.get("agg", "last") if daily else "last")
        out[c] = transform(q, spec["transform"])

    P = pd.DataFrame(out)
    P = P.loc[P.notna().any(axis=1)]
    Ybal = P.dropna()
    if len(Ybal) == 0:
        raise ValueError("no balanced observations after transforms")
    # warn about interior gaps (holes strictly inside the balanced span)
    inner = P.loc[Ybal.index[0]:Ybal.index[-1]]
    n_holes = int(inner.isna().any(axis=1).sum())
    if n_holes:
        print(f"    WARNING: {n_holes} months inside the sample have missing "
              f"values and are dropped from estimation")
    Ybal = inner.dropna()
    ragged = P.loc[P.index > Ybal.index[-1]]
    if len(ragged) > cfg["max_ragged_months"]:
        print(f"    WARNING: ragged edge is {len(ragged)} months; keeping the "
              f"first {cfg['max_ragged_months']} (check your data)")
        ragged = ragged.iloc[:cfg["max_ragged_months"]]
    return P, Ybal, ragged


# ==============================================================================
# Minnesota-prior BVAR via dummy observations (Banbura et al. 2010)
# ==============================================================================

def ar_resid_sigmas(Y: np.ndarray, p: int) -> np.ndarray:
    """Scale parameters sigma_i: residual std of univariate AR(p) per series."""
    T, n = Y.shape
    sig = np.empty(n)
    for i in range(n):
        y = Y[:, i]
        X = np.column_stack([y[p - l - 1:T - l - 1] for l in range(p)]
                            + [np.ones(T - p)])
        yy = y[p:]
        beta, *_ = np.linalg.lstsq(X, yy, rcond=None)
        r = yy - X @ beta
        sig[i] = max(np.std(r, ddof=min(X.shape[1], len(yy) - 1)), 1e-8)
    return sig


def build_dummies(n, p, sig, delta, lam, decay, soc_mu, dio_tau, ybar,
                  n_exog):
    """
    Dummy observations encoding the priors. Regressor ordering:
    [lag1 vars ... lagp vars, intercept, exog dummies].
    """
    k = n * p + 1 + n_exog
    rows_Y, rows_X = [], []

    # (1) Minnesota prior on lag coefficients
    for l in range(1, p + 1):
        Yd = np.zeros((n, n))
        Xd = np.zeros((n, k))
        for i in range(n):
            scale = sig[i] * (l ** decay) / lam
            if l == 1:
                Yd[i, i] = delta[i] * scale
            Xd[i, (l - 1) * n + i] = scale
        rows_Y.append(Yd); rows_X.append(Xd)

    # (2) prior on Sigma (n rows)
    rows_Y.append(np.diag(sig)); rows_X.append(np.zeros((n, k)))

    # (3) loose prior on intercept and exog dummies (tiny precision)
    eps = 1e-4
    for j in range(1 + n_exog):
        Yd = np.zeros((1, n)); Xd = np.zeros((1, k))
        Xd[0, n * p + j] = eps
        rows_Y.append(Yd); rows_X.append(Xd)

    # (4) sum-of-coefficients prior (Doan/Sims), mu -> 0 = tight
    if soc_mu is not None:
        Yd = np.diag(delta * ybar) / soc_mu
        Xd = np.zeros((n, k))
        for l in range(p):
            Xd[:, l * n:(l + 1) * n] = np.diag(delta * ybar) / soc_mu
        rows_Y.append(Yd); rows_X.append(Xd)

    # (5) dummy initial observation (Sims co-persistence)
    if dio_tau is not None:
        Yd = (ybar / dio_tau).reshape(1, n)
        Xd = np.zeros((1, k))
        for l in range(p):
            Xd[0, l * n:(l + 1) * n] = ybar / dio_tau
        Xd[0, n * p] = 1.0 / dio_tau
        rows_Y.append(Yd); rows_X.append(Xd)

    return np.vstack(rows_Y), np.vstack(rows_X)


def design_matrices(Y: np.ndarray, p: int, exog):
    T, n = Y.shape
    X = np.column_stack([Y[p - l - 1:T - l - 1, :] for l in range(p)]
                        + [np.ones((T - p, 1))])
    if exog is not None:
        X = np.column_stack([X, exog[p:]])
    return Y[p:], X


class MinnesotaBVAR:
    def __init__(self, p, lam, decay, soc_mu, dio_tau, delta):
        self.p, self.lam, self.decay = p, lam, decay
        self.soc_mu, self.dio_tau, self.delta = soc_mu, dio_tau, delta

    # ---------------------------------------------------------------- fit ----
    def fit(self, Y: np.ndarray, exog: np.ndarray | None = None):
        p = self.p
        T, n = Y.shape
        self.n = n
        self.n_exog = 0 if exog is None else exog.shape[1]
        sig = ar_resid_sigmas(Y, p)
        ybar = Y[:p].mean(axis=0)
        Yd, Xd = build_dummies(n, p, sig, self.delta, self.lam, self.decay,
                               self.soc_mu, self.dio_tau, ybar, self.n_exog)
        Yt, Xt = design_matrices(Y, p, exog)
        Ys, Xs = np.vstack([Yt, Yd]), np.vstack([Xt, Xd])

        XtX = Xs.T @ Xs
        self.XtX_inv = np.linalg.inv(XtX + 1e-10 * np.eye(XtX.shape[0]))
        self.B_post = self.XtX_inv @ Xs.T @ Ys
        R = Ys - Xs @ self.B_post
        self.S_post = R.T @ R
        self.dof = Yt.shape[0] + Yd.shape[0] - Xs.shape[1]
        self._ml_pieces = (Yd, Xd, Yt, Xt)
        self.k = Xs.shape[1]
        return self

    # ------------------------------------------------- marginal likelihood ---
    def log_ml(self) -> float:
        Yd, Xd, Yt, Xt = self._ml_pieces
        n = self.n; k = self.k
        Td, T = Yd.shape[0], Yt.shape[0]

        def niw_pieces(Ya, Xa):
            XtX = Xa.T @ Xa + 1e-10 * np.eye(k)
            B = np.linalg.solve(XtX, Xa.T @ Ya)
            R = Ya - Xa @ B
            S = R.T @ R + 1e-10 * np.eye(n)
            return slogdet(XtX)[1], slogdet(S)[1]

        ld_X0, ld_S0 = niw_pieces(Yd, Xd)
        ld_X1, ld_S1 = niw_pieces(np.vstack([Yt, Yd]), np.vstack([Xt, Xd]))
        a0 = Td - k
        a1 = Td + T - k
        if a0 <= n or a1 <= n:
            return -np.inf
        lml = (-0.5 * n * T * np.log(np.pi)
               + multigammaln(a1 / 2, n) - multigammaln(a0 / 2, n)
               + 0.5 * n * (ld_X0 - ld_X1)
               + 0.5 * (a0 * ld_S0 - a1 * ld_S1))
        return float(lml)

    # ----------------------------------------- posterior parameter sampling --
    def _draw_params(self, rng):
        n = self.n
        Sigma = stats.invwishart.rvs(df=max(self.dof, n + 2),
                                     scale=self.S_post, random_state=rng)
        Sigma = np.atleast_2d(Sigma)
        cS = cholesky(Sigma + 1e-12 * np.eye(n))
        if not hasattr(self, "_cholX"):
            self._cholX = cholesky(self.XtX_inv + 1e-12 * np.eye(self.k))
        B = self.B_post + self._cholX @ rng.standard_normal((self.k, n)) @ cS.T
        return B, Sigma, cS

    # ------------------------------------- conditional predictive simulation -
    def conditional_paths(self, Y, H, conditions, n_draws, rng,
                          exog_future=None) -> np.ndarray:
        """
        Exact conditional forecasting with hard conditions (Waggoner-Zha 1999)
        under parameter uncertainty. For each posterior draw (B, Sigma) the
        stacked future vector [y_{T+1}',...,y_{T+H}']' is Gaussian:
            mean  = deterministic iteration of the VAR,
            Cov(y_{T+i}, y_{T+j}) = sum_{s=1..min(i,j)} Psi_{i-s} Sigma Psi_{j-s}'
        with Psi the MA(inf) matrices. We condition analytically on every
        released value (stacked index (h-1)*n + var) and simulate the rest.

        conditions : dict {stacked_index: value}, empty dict = unconditional.
        Returns draws of future paths: (n_draws, H, n).
        """
        p, n = self.p, self.n
        obs_ix = sorted(conditions.keys())
        obs_v = np.array([conditions[i] for i in obs_ix], dtype=float)
        un_ix = [i for i in range(H * n) if i not in set(obs_ix)]
        out = np.empty((n_draws, H, n))
        hist = Y[-p:].copy()

        for d in range(n_draws):
            B, Sigma, _ = self._draw_params(rng)
            A = [B[l * n:(l + 1) * n, :].T for l in range(p)]   # A_1..A_p

            # deterministic mean path
            lags = hist.copy()
            M = np.empty((H, n))
            for h in range(H):
                x = np.concatenate([lags[-l - 1] for l in range(p)] + [[1.0]])
                if self.n_exog:
                    xf = (exog_future[h] if exog_future is not None
                          else np.zeros(self.n_exog))
                    x = np.concatenate([x, xf])
                M[h] = x @ B
                lags = np.vstack([lags, M[h]])

            # MA matrices Psi_0..Psi_{H-1}
            Psi = [np.eye(n)]
            for h in range(1, H):
                acc = np.zeros((n, n))
                for l in range(1, min(h, p) + 1):
                    acc += A[l - 1] @ Psi[h - l]
                Psi.append(acc)

            # stacked covariance
            C = np.zeros((H * n, H * n))
            for i in range(1, H + 1):
                for j in range(i, H + 1):
                    blk = np.zeros((n, n))
                    for s in range(1, i + 1):
                        blk += Psi[i - s] @ Sigma @ Psi[j - s].T
                    C[(i - 1) * n:i * n, (j - 1) * n:j * n] = blk
                    if i != j:
                        C[(j - 1) * n:j * n, (i - 1) * n:i * n] = blk.T
            mvec = M.reshape(-1)

            path = np.empty(H * n)
            if obs_ix:
                Coo = C[np.ix_(obs_ix, obs_ix)] + 1e-10 * np.eye(len(obs_ix))
                Cuo = C[np.ix_(un_ix, obs_ix)]
                Cuu = C[np.ix_(un_ix, un_ix)]
                sol = np.linalg.solve(Coo, obs_v - mvec[obs_ix])
                mu_c = mvec[un_ix] + Cuo @ sol
                Cov_c = Cuu - Cuo @ np.linalg.solve(Coo, Cuo.T)
                Cov_c = 0.5 * (Cov_c + Cov_c.T)
                L = cholesky(Cov_c + 1e-8 * np.eye(len(un_ix)))
                path[obs_ix] = obs_v
                path[un_ix] = mu_c + L @ rng.standard_normal(len(un_ix))
            else:
                L = cholesky(C + 1e-8 * np.eye(H * n))
                path = mvec + L @ rng.standard_normal(H * n)
            out[d] = path.reshape(H, n)
        return out

    def sample_forecasts(self, Y, H, n_draws, rng, exog_future=None):
        """Unconditional predictive draws (special case: no conditions)."""
        return self.conditional_paths(Y, H, {}, n_draws, rng, exog_future)


# ==============================================================================
# Hyperparameter search (marginal likelihood grid, GLP 2015)
# ==============================================================================

def select_hyperparams(Y, exog, cfg, delta, verbose=True):
    best = (-np.inf, None)
    for lam in cfg["lambda_grid"]:
        for mu in cfg["soc_grid"]:
            for tau in cfg["dio_grid"]:
                m = MinnesotaBVAR(cfg["n_lags"], lam, cfg["lag_decay"],
                                  mu, tau, delta).fit(Y, exog)
                lml = m.log_ml()
                if lml > best[0]:
                    best = (lml, (lam, mu, tau))
    lam, mu, tau = best[1]
    if verbose:
        print(f"    selected: lambda={lam}, soc_mu={mu}, dio_tau={tau} "
              f"(log-ML={best[0]:.2f})")
    return lam, mu, tau


# ==============================================================================
# Benchmarks
# ==============================================================================

def ar_benchmark_forecast(y: np.ndarray, p: int, h: int) -> float:
    """Iterated AR(p) OLS forecast h steps ahead."""
    T = len(y)
    X = np.column_stack([y[p - l - 1:T - l - 1] for l in range(p)]
                        + [np.ones(T - p)])
    beta, *_ = np.linalg.lstsq(X, y[p:], rcond=None)
    hist = list(y[-p:])
    for _ in range(h):
        x = np.array(hist[::-1][:p] + [1.0])
        hist.append(float(x @ beta))
    return hist[-1]


def ao_benchmark(y: np.ndarray) -> float:
    """Atkeson-Ohanian (2001): forecast = mean of the last 12 monthly obs."""
    return float(np.mean(y[-12:]))


# ==============================================================================
# Recursive out-of-sample backtest (incl. pseudo-real-time CPI-conditioning)
# ==============================================================================

def run_backtest(Yq: pd.DataFrame, exog_df, cfg, delta, hyper, rng):
    tcol = cfg["target_col"]
    cols = list(Yq.columns)
    tgt_j = cols.index(tcol)
    cond_cols = [c for c in cfg.get("nowcast_condition_cols", [])
                 if c in cols and c != tcol]
    cond_js = [cols.index(c) for c in cond_cols]

    lam, mu, tau = hyper
    origins = Yq.index[Yq.index >= pd.Timestamp(cfg["oos_start"])]
    origins = origins[::max(int(cfg.get("oos_step", 1)), 1)]
    Hmax = max(cfg["oos_horizons"])
    rows = []
    for step, t0 in enumerate(origins):
        i0 = Yq.index.get_loc(t0)
        if i0 + Hmax >= len(Yq):
            break
        Ytr = Yq.iloc[:i0 + 1]
        Etr = exog_df.iloc[:i0 + 1].values if exog_df is not None else None
        if (cfg["reoptimize_each_step"]
                and step % max(int(cfg.get("hyper_reopt_every", 1)), 1) == 0):
            lam, mu, tau = select_hyperparams(Ytr.values, Etr, cfg, delta,
                                              verbose=False)
        m = MinnesotaBVAR(cfg["n_lags"], lam, cfg["lag_decay"],
                          mu, tau, delta).fit(Ytr.values, Etr)

        nd = int(cfg.get("oos_draws", 400))
        draws = m.sample_forecasts(Ytr.values, Hmax, nd, rng)

        # pseudo-real-time conditional nowcast: month t0+1, conditioning on
        # the (already published in real life) CPI-block values of that month
        cond = {0 * len(cols) + j: float(Yq.iloc[i0 + 1, j]) for j in cond_js}
        cdraws = m.conditional_paths(Ytr.values, 1, cond, nd, rng)
        cfc = cdraws[:, 0, tgt_j]

        for h in cfg["oos_horizons"]:
            fc = draws[:, h - 1, tgt_j]
            rec = {
                "origin": t0, "h": h,
                "actual": Yq[tcol].iloc[i0 + h],
                "bvar_mean": fc.mean(),
                "bvar_lo68": np.quantile(fc, 0.16),
                "bvar_hi68": np.quantile(fc, 0.84),
                "ar_bench": ar_benchmark_forecast(Ytr[tcol].values,
                                                  cfg["n_lags"], h),
                "ao": ao_benchmark(Ytr[tcol].values),
                "hist_mean": Ytr[tcol].mean(),
            }
            if h == 1:
                rec.update({
                    "bvar_cond_mean": cfc.mean(),
                    "bvar_cond_lo68": np.quantile(cfc, 0.16),
                    "bvar_cond_hi68": np.quantile(cfc, 0.84),
                })
            rows.append(rec)
    return pd.DataFrame(rows)


def backtest_summary(bt: pd.DataFrame, cfg) -> str:
    lines = []
    for h in cfg["oos_horizons"]:
        b = bt[bt["h"] == h]
        if len(b) == 0:
            continue
        rmse = lambda c: np.sqrt(np.mean((b["actual"] - b[c]) ** 2))
        r_b, r_ar, r_ao, r_mn = (rmse("bvar_mean"), rmse("ar_bench"),
                                 rmse("ao"), rmse("hist_mean"))
        cov = np.mean((b["actual"] >= b["bvar_lo68"])
                      & (b["actual"] <= b["bvar_hi68"]))
        line = (f"  h={h:>2}: BVAR RMSE={r_b:.3f} | AR({cfg['n_lags']})="
                f"{r_ar:.3f} (ratio {r_b / r_ar:.3f}) | AO={r_ao:.3f} "
                f"(ratio {r_b / r_ao:.3f}) | mean={r_mn:.3f} "
                f"| 68% cov={cov:.0%} | n={len(b)}")
        if h == 1 and "bvar_cond_mean" in b.columns:
            r_c = rmse("bvar_cond_mean")
            ccov = np.mean((b["actual"] >= b["bvar_cond_lo68"])
                           & (b["actual"] <= b["bvar_cond_hi68"]))
            line += (f"\n        conditional nowcast (given CPI-block): "
                     f"RMSE={r_c:.3f} (vs uncond {r_b:.3f}, ratio "
                     f"{r_c / r_b:.3f}) | 68% cov={ccov:.0%}")
        lines.append(line)
    return "\n".join(lines)


