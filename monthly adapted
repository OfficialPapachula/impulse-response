def build_conditions(ragged: pd.DataFrame, cols, cfg):
    """Stacked-index hard conditions from the ragged edge + manual overrides."""
    n = len(cols)
    conds, desc = {}, []
    for h, (dt, row) in enumerate(ragged.iterrows(), start=1):
        got = []
        for j, c in enumerate(cols):
            v = row[c]
            if pd.notna(v):
                conds[(h - 1) * n + j] = float(v)
                got.append(f"{c}={v:.2f}")
        if got:
            desc.append(f"{dt:%Y-%m}: " + ", ".join(got))
    for dstr, dd in cfg.get("manual_conditions", {}).items():
        per = pd.Period(dstr, freq="M")
        # h index relative to last balanced month
        h = None
        for hh, dt in enumerate(ragged.index, start=1):
            if dt.to_period("M") == per:
                h = hh
        if h is None:
            h = len(ragged) + (per - ragged.index[-1].to_period("M")).n \
                if len(ragged) else (per.ordinal + 1)
            print(f"    NOTE: manual condition month {dstr} beyond ragged "
                  f"edge -> mapped to h={h}")
        for c, v in dd.items():
            if c in cols:
                conds[(h - 1) * n + cols.index(c)] = float(v)
                desc.append(f"{dstr} (manual): {c}={v:.2f}")
    return conds, desc


def run(cfg):
    rng = np.random.default_rng(cfg["seed"])
    os.makedirs(cfg["output_dir"], exist_ok=True)
    tcol = cfg["target_col"]

    print("=" * 78)
    print(f"BVAR PCE INFLATION FORECAST -- target: {tcol}")
    print("=" * 78)

    P, Yq, ragged = load_monthly(cfg)
    cols = list(Yq.columns)
    n = len(cols)
    tgt_j = cols.index(tcol)
    print(f"\n[1] Monthly panel (balanced): {Yq.shape[0]} months x {n} vars, "
          f"{Yq.index[0].date()} - {Yq.index[-1].date()}")
    print(Yq.describe().T[["mean", "std", "min", "max"]].round(3))
    if len(ragged):
        print(f"    ragged edge ({len(ragged)} month(s), {tcol} not yet "
              f"released):")
        print(ragged.round(3).to_string())

    # outlier dummies (monthly periods)
    exog_df = None
    if cfg["outlier_dummies"]:
        exog_df = pd.DataFrame(
            0.0, index=Yq.index,
            columns=[f"D_{q}" for q in cfg["outlier_dummies"]])
        for q in cfg["outlier_dummies"]:
            per = pd.Period(q, freq="M")
            exog_df.loc[Yq.index.to_period("M") == per, f"D_{q}"] = 1.0
        print(f"    outlier dummies: {cfg['outlier_dummies']}")

    # prior means
    if cfg["prior_mean_delta"] == "auto":
        delta = np.array([
            0.0 if is_growth_like(cfg["target_transform"] if c == tcol
                                  else cfg["predictors"][c]["transform"])
            else 0.9
            for c in cols])
    else:
        delta = np.array([cfg["prior_mean_delta"][c] for c in cols])
    print(f"    prior own-lag means delta: {dict(zip(cols, delta.round(2)))}")

    print("\n[2] Hyperparameter selection (marginal likelihood, GLP 2015)")
    E = exog_df.values if exog_df is not None else None
    hyper = select_hyperparams(Yq.values, E, cfg, delta)

    print(f"\n[3] Recursive out-of-sample backtest "
          f"(origins from {cfg['oos_start']})")
    bt = run_backtest(Yq, exog_df, cfg, delta, hyper, rng)
    summ = backtest_summary(bt, cfg)
    print(summ)
    bt.to_csv(os.path.join(cfg["output_dir"], "backtest.csv"), index=False)
    plot_oos(bt, cfg, os.path.join(cfg["output_dir"], "oos_forecasts.png"))

    # ---- full-sample fit ------------------------------------------------------
    print(f"\n[4] Full-sample fit + {cfg['horizon']}-month density forecast "
          f"({cfg['n_draws']} draws)")
    lam, mu, tau = hyper
    m = MinnesotaBVAR(cfg["n_lags"], lam, cfg["lag_decay"], mu, tau,
                      delta).fit(Yq.values, E)
    p = cfg["n_lags"]
    rows = [f"{v}.L{l}" for l in range(1, p + 1) for v in cols]
    rows += ["const"] + (list(exog_df.columns) if exog_df is not None else [])
    print("-" * 78)
    print(f"{tcol} equation coefficients (posterior mean, first 2 lags):")
    ser = pd.Series(m.B_post[:, tgt_j], index=rows)
    print(ser.iloc[:2 * n].round(3).to_string())
    print("-" * 78)

    # ---- conditions from the ragged edge (CPI already out, PCE not) -----------
    conds, cond_desc = build_conditions(ragged, cols, cfg)
    if cond_desc:
        print("\n[5] NOWCAST -- conditioning on released prints "
              "(Waggoner-Zha hard conditions):")
        for s in cond_desc:
            print("      " + s)
    else:
        print("\n[5] NOWCAST -- no ragged edge detected; next-month forecast "
              "is unconditional")

    H = max(cfg["horizon"], len(ragged) if len(ragged) else 1)
    draws_c = m.conditional_paths(Yq.values, H, conds, cfg["n_draws"], rng)
    draws_u = m.conditional_paths(Yq.values, H, {}, cfg["n_draws"], rng)

    fdates = pd.period_range(Yq.index[-1], periods=H + 1,
                             freq="M")[1:].to_timestamp(how="end")

    # nowcast table: every ragged month where the target is missing
    now_rows = []
    n_now = max(len(ragged), 1)
    for h in range(1, n_now + 1):
        d_c = draws_c[:, h - 1, tgt_j]
        d_u = draws_u[:, h - 1, tgt_j]
        label = fdates[h - 1].strftime("%Y-%m")
        row = {
            "month": label,
            "mean": d_c.mean(), "median": np.median(d_c),
            "lo68": np.quantile(d_c, 0.16), "hi68": np.quantile(d_c, 0.84),
            "lo90": np.quantile(d_c, 0.05), "hi90": np.quantile(d_c, 0.95),
            "uncond_mean": d_u.mean(),
            "sd_ratio_cond/uncond": d_c.std() / max(d_u.std(), 1e-12),
        }
        for thr in cfg.get("nowcast_thresholds", []):
            row[f"P(>{thr})"] = float((d_c > thr).mean())
        row["P(<0)"] = float((d_c < 0).mean())
        now_rows.append(row)
        if h == 1:
            plot_nowcast(d_c, d_u, f"{tcol} {label}",
                         os.path.join(cfg["output_dir"],
                                      "nowcast_density.png"))
            # implied y/y for the next print, if modeling annualized m/m
            if cfg["target_transform"] == "ann_log_growth" and len(Yq) >= 11:
                dl_hist = Yq[tcol].iloc[-11:].values / 1200.0
                yoy = 100.0 * (dl_hist.sum() + d_c / 1200.0)
                print(f"      implied {label} y/y: mean {yoy.mean():.2f}%, "
                      f"68% [{np.quantile(yoy, 0.16):.2f}, "
                      f"{np.quantile(yoy, 0.84):.2f}]")
    now = pd.DataFrame(now_rows)
    print(f"\n    Next-print nowcast for {tcol} "
          f"({cfg['target_transform']} units):")
    print(now.round(3).to_string(index=False))
    now.to_csv(os.path.join(cfg["output_dir"], "nowcast.csv"), index=False)

    # ---- full forecast path (conditional draws) -------------------------------
    fc = pd.DataFrame({
        "month": [d.strftime("%Y-%m") for d in fdates],
        "median": np.median(draws_c[:, :, tgt_j], axis=0),
        "mean": draws_c[:, :, tgt_j].mean(axis=0),
        "lo68": np.quantile(draws_c[:, :, tgt_j], 0.16, axis=0),
        "hi68": np.quantile(draws_c[:, :, tgt_j], 0.84, axis=0),
        "lo90": np.quantile(draws_c[:, :, tgt_j], 0.05, axis=0),
        "hi90": np.quantile(draws_c[:, :, tgt_j], 0.95, axis=0),
        "prob_above_2": (draws_c[:, :, tgt_j] > 2.0).mean(axis=0),
        "prob_negative": (draws_c[:, :, tgt_j] < 0).mean(axis=0),
    })
    print(f"\n    {cfg['horizon']}-month path (conditional on released data):")
    print(fc.round(2).to_string(index=False))
    fc.to_csv(os.path.join(cfg["output_dir"], "forecast.csv"), index=False)
    plot_fan(Yq, draws_c, fdates, cfg,
             os.path.join(cfg["output_dir"], "fan_chart.png"), len(conds))

    # ---- summary --------------------------------------------------------------
    with open(os.path.join(cfg["output_dir"], "summary.txt"), "w") as f:
        f.write("BVAR PCE inflation forecast summary\n" + "=" * 40 + "\n")
        f.write(f"sample: {Yq.index[0].date()} - {Yq.index[-1].date()} "
                f"({len(Yq)} months)\n")
        f.write(f"vars: {cols}\nlags: {cfg['n_lags']}\n")
        f.write(f"hyperparams: lambda={lam}, soc={mu}, dio={tau}\n")
        if cond_desc:
            f.write("nowcast conditions:\n  " + "\n  ".join(cond_desc) + "\n")
        f.write("\nOut-of-sample:\n" + summ + "\n")
        f.write("\nNext-print nowcast:\n" + now.round(3).to_string(index=False))
        f.write("\n\nForecast path:\n"
                + fc.round(3).to_string(index=False) + "\n")
    print(f"\nOutputs -> {os.path.abspath(cfg['output_dir'])}/")
    return bt, now, fc


# ==============================================================================
# Self-test: synthetic aligned monthly panel with a ragged edge
# ==============================================================================

def make_synthetic_monthly(seed=7):
    """
    Monthly panel 1999-01..2026-06. ENERGY leads; CPI and PCE share a common
    core + a contemporaneous shock, so CPI(t) is genuinely informative about
    PCE(t). Last month: CPI/ENERGY released, PCE = NaN (the ragged edge).
    """
    rng = np.random.default_rng(seed)
    dates = pd.date_range("1999-01-31", "2026-06-30", freq="ME")
    T = len(dates)
    energy = np.zeros(T); core = np.zeros(T)
    cpi = np.zeros(T); pce = np.zeros(T)
    for t in range(1, T):
        energy[t] = 0.6 * energy[t - 1] + rng.normal(0, 1.5)
        u2 = rng.normal(0, 0.6)
        core[t] = 0.6 * core[t - 1] + 0.8 + 0.25 * energy[t - 1] \
            + rng.normal(0, 0.4)
        cpi[t] = core[t] + 0.9 * energy[t] + u2
        pce[t] = 0.85 * core[t] + 0.55 * energy[t] + 0.7 * u2 \
            + rng.normal(0, 0.35)
    noise = rng.normal(0, 1, T)
    df = pd.DataFrame({"Date": dates, "PCE": pce + 2.0, "CPI": cpi + 2.3,
                       "ENERGY": energy, "NOISE": noise})
    df.loc[df.index[-1], "PCE"] = np.nan          # PCE not yet released
    return df


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("--selftest", action="store_true")
    ap.add_argument("--excel", default=None)
    args = ap.parse_args()

    cfg = dict(CONFIG)
    if args.excel:
        cfg["excel_path"] = args.excel

    if args.selftest:
        print(">> SELF-TEST: synthetic aligned monthly panel; CPI(t) is "
              "informative about PCE(t); last-month PCE missing (ragged "
              "edge); NOISE is useless.\n")
        panel = make_synthetic_monthly()
        path = os.path.join(os.getcwd(), "bvar_selftest_inflation.xlsx")
        panel.to_excel(path, index=False)
        cfg.update({
            "excel_path": path,
            "output_dir": "bvar_output_selftest",
            "data_frequency": "monthly",
            "target_col": "PCE",
            "target_transform": "level",
            "target_release_shift_m": 0,
            "predictors": {
                "CPI":    {"transform": "level", "agg": "last"},
                "ENERGY": {"transform": "level", "agg": "last"},
                "NOISE":  {"transform": "level", "agg": "last"},
            },
            "nowcast_condition_cols": ["CPI", "ENERGY"],
            "outlier_dummies": [],
            "n_lags": 6,
            "oos_start": "2018-01-01",
            "oos_horizons": [1, 12],
            "oos_step": 2,
            "oos_draws": 250,
            "n_draws": 2000,
            "nowcast_thresholds": [2.0],
        })
    elif not os.path.exists(cfg["excel_path"]):
        sys.exit(f"Excel not found: {cfg['excel_path']} "
                 "(edit CONFIG, pass --excel, or run --selftest)")

    run(cfg)


if __name__ == "__main__":
    main()
